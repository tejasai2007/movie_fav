# .env.local.example - Copy to .env.local and set your backend URL
# When deploying to Vercel, add this as an Environment Variable in the dashboard

# The URL where your Flask backend is running
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:5000

# Production example (replace with your real backend URL):
# NEXT_PUBLIC_API_URL=https://your-backend.railway.app
